generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  name            String?
  passwordHash    String?
  setupToken      String?             @unique
  // Product-admin approval flow (only for new family heads)
  approvalStatus  String              @default("APPROVED") // APPROVED | PENDING
  approvalToken   String?             @unique
  householdId     String?
  household       Household?          @relation(fields: [householdId], references: [id])
  role            String              @default("MEMBER")
  events          Event[]
  createdAt       DateTime            @default(now())
  // 2FA
  otpSecret       String?
  otpEnabled      Boolean             @default(false)
  // Finance
  language        String              @default("he")
  theme           String              @default("light")
  // Finance relations
  financialAssets FinancialAsset[]
  financialGoals  FinancialGoal[]
  notifications   Notification[]
  assetSnapshots  AssetSnapshot[]
}

model Household {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  // Token for product-admin to revoke this household
  revokeToken String?   @unique
  categories Category[]
  events     Event[]
  invites    Invite[]
  members    User[]
}

model Invite {
  id          String    @id @default(cuid())
  householdId String
  code        String    @unique
  createdById String
  expiresAt   DateTime?
  usedById    String?
  household   Household @relation(fields: [householdId], references: [id])
}

model Category {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String?
  icon        String?
  color       String?
  position    Int        @default(0)
  isActive    Boolean    @default(true)
  householdId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
  household   Household? @relation(fields: [householdId], references: [id])
}

model Activity {
  id            String   @id @default(cuid())
  key           String   @unique
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  icon          String?
  defaultPoints Int      @default(10)
  frequency     String   @default("DAILY")
  position      Int      @default(0)
  isActive      Boolean  @default(true)
  requiresNote  Boolean  @default(false)
  requiresPhoto Boolean  @default(false)
  config        String?
  createdById   String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  events        Event[]
}

model Task {
  id            String   @id @default(cuid())
  key           String   @unique
  categoryId    String?
  name          String
  description   String?
  defaultPoints Int
  frequency     String
  eligibility   String?
  penaltyRules  String?
  createdById   String
  createdAt     DateTime @default(now())
}

model Event {
  id           String    @id @default(cuid())
  eventType    String
  occurredAt   DateTime  @default(now())
  recordedById String
  recordedBy   User      @relation(fields: [recordedById], references: [id])
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])
  taskId       String?
  activityId   String?
  activity     Activity? @relation(fields: [activityId], references: [id])
  points       Int       @default(0)
  metadata     String?
}

model BugReport {
  id          String    @id @default(cuid())
  title       String
  description String
  reportedBy  String?
  createdAt   DateTime  @default(now())
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
}

// ────────────────────────────────────────────────
// FINANCAL APP MODELS
// ────────────────────────────────────────────────

model FinancialAsset {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  name          String
  institution   String
  accountNumber String?
  currency      String          @default("ILS")
  currentValue  Float           @default(0)
  ticker        String?
  quantity      Float?
  purchasePrice Float?
  purchaseDate  DateTime?
  interestRate  Float?
  maturityDate  DateTime?
  monthlyDeposit Float?
  employerContribution Float?
  expectedReturnRate Float?
  bankCode      String?
  branchCode    String?
  notes         String?
  isActive      Boolean         @default(true)
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  snapshots     AssetSnapshot[]
}

model AssetSnapshot {
  id        String         @id @default(cuid())
  assetId   String
  asset     FinancialAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  value     Float
  date      DateTime
  createdAt DateTime       @default(now())
}

model FinancialGoal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  targetAmount Float
  currentAmount Float   @default(0)
  targetDate  DateTime?
  category    String?
  notes       String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  titleHe   String?
  message   String
  messageHe String?
  isRead    Boolean  @default(false)
  metadata  String?
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("2fa")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
