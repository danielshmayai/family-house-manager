generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String              @id @default(cuid())
  email           String              @unique
  name            String?
  passwordHash    String?
  setupToken      String?             @unique
  // Product-admin approval flow (only for new family heads)
  approvalStatus  String              @default("APPROVED") // APPROVED | PENDING
  approvalToken   String?             @unique
  householdId     String?
  household       Household?          @relation(fields: [householdId], references: [id])
  role            String              @default("MEMBER")
  events          Event[]
  createdAt       DateTime            @default(now())
  // 2FA
  otpSecret       String?
  otpEnabled      Boolean             @default(false)
  language        String              @default("he")
  theme           String              @default("light")
  // My Tasks
  tasksAssigned   UserTask[]          @relation("TasksAssignedBy")
  tasksReceived   UserTask[]          @relation("TasksAssignedTo")
}

model Household {
  id         String     @id @default(cuid())
  name       String
  createdAt  DateTime   @default(now())
  // Token for product-admin to revoke this household
  revokeToken String?   @unique
  categories Category[]
  events     Event[]
  invites    Invite[]
  members    User[]
  userTasks  UserTask[]
}

model Invite {
  id          String    @id @default(cuid())
  householdId String
  code        String    @unique
  createdById String
  expiresAt   DateTime?
  usedById    String?
  household   Household @relation(fields: [householdId], references: [id])
}

model Category {
  id          String     @id @default(cuid())
  key         String     @unique
  name        String
  description String?
  icon        String?
  color       String?
  position    Int        @default(0)
  isActive    Boolean    @default(true)
  householdId String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  activities  Activity[]
  household   Household? @relation(fields: [householdId], references: [id])
}

model Activity {
  id            String     @id @default(cuid())
  key           String     @unique
  categoryId    String
  category      Category   @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  name          String
  description   String?
  icon          String?
  defaultPoints Int        @default(10)
  frequency     String     @default("DAILY")
  position      Int        @default(0)
  isActive      Boolean    @default(true)
  requiresNote  Boolean    @default(false)
  requiresPhoto Boolean    @default(false)
  config        String?
  createdById   String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  events        Event[]
  userTasks     UserTask[]
}

model Task {
  id            String   @id @default(cuid())
  key           String   @unique
  categoryId    String?
  name          String
  description   String?
  defaultPoints Int
  frequency     String
  eligibility   String?
  penaltyRules  String?
  createdById   String
  createdAt     DateTime @default(now())
}

model Event {
  id           String    @id @default(cuid())
  eventType    String
  occurredAt   DateTime  @default(now())
  recordedById String
  recordedBy   User      @relation(fields: [recordedById], references: [id])
  householdId  String
  household    Household @relation(fields: [householdId], references: [id])
  taskId       String?
  activityId   String?
  activity     Activity? @relation(fields: [activityId], references: [id])
  points       Int       @default(0)
  metadata     String?
}

model UserTask {
  id           String    @id @default(cuid())
  title        String
  description  String?
  activityId   String?
  assignedById String
  assignedToId String
  householdId  String
  isCompleted  Boolean   @default(false)
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  activity     Activity? @relation(fields: [activityId], references: [id])
  assignedBy   User      @relation("TasksAssignedBy", fields: [assignedById], references: [id], onDelete: Cascade)
  assignedTo   User      @relation("TasksAssignedTo", fields: [assignedToId], references: [id], onDelete: Cascade)
  household    Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
}

model BugReport {
  id          String    @id @default(cuid())
  title       String
  description String
  reportedBy  String?
  createdAt   DateTime  @default(now())
  resolved    Boolean   @default(false)
  resolvedAt  DateTime?
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  type      String   @default("2fa")
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}
