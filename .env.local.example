# ============================================================
#  LOCAL DEVELOPMENT SETUP
#  1. Copy this file to .env.local
#  2. Fill in your real Neon credentials below
#  3. Run: npm install && npx prisma db push && npm run dev
# ============================================================

# Neon PostgreSQL
# Go to: neon.tech → your project → Connect → Prisma → .env tab
# Connection pooling ON  → DATABASE_URL  (has -pooler in the URL)
# Connection pooling OFF → DIRECT_URL    (no -pooler in the URL)
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="NevhbnRFIzVu2XQA5sa2SYbHaTzAYDm1KTG/Vqtwkis="

# App
NEXT_PUBLIC_APP_NAME="FinanSee"
OTP_EMAIL_FROM="noreply@finansee.app"
