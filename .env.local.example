# ============================================================
#  LOCAL DEVELOPMENT SETUP
#  1. Copy this file:  cp .env.local.example .env.local
#  2. Fill in your real Neon DATABASE_URL below
#  3. Run:  npm install && npx prisma db push && npm run dev
# ============================================================

# Neon PostgreSQL — only DATABASE_URL is required locally.
# Go to: neon.tech → your project → Connect → copy "Connection string"
DATABASE_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require"

# DIRECT_URL is optional — only needed on Vercel when using PgBouncer pooling.
# If you want to enable it locally too, uncomment schema.prisma line 9 as well.
# DIRECT_URL="postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx.c-4.us-east-1.aws.neon.tech/neondb?sslmode=require"

# NextAuth — keep these exactly as-is for local dev
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="NevhbnRFIzVu2XQA5sa2SYbHaTzAYDm1KTG/Vqtwkis="

# App
NEXT_PUBLIC_APP_NAME="FinanSee"
OTP_EMAIL_FROM="noreply@finansee.app"
