{
  "name": "family-house-manager",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "postinstall": "prisma generate",
    "prisma:migrate": "prisma migrate dev --name init",
    "prisma:generate": "prisma generate",
    "prisma:reset": "prisma migrate reset",
    "prisma:deploy": "prisma migrate deploy",
    "seed": "tsx prisma/seed.ts",
    "seed:modular": "tsx prisma/seed-modular.ts",
    "seed:finance": "tsx prisma/seed-finance.ts",
    "setup": "npm install && prisma migrate dev && npm run seed:modular",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@flydotio/litestream": "^1.0.1",
    "@prisma/client": "6.19.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/otplib": "^7.0.0",
    "autoprefixer": "^10.4.24",
    "bcryptjs": "2.4.3",
    "clsx": "2.1.0",
    "date-fns": "3.0.6",
    "next": "15.3.9",
    "next-auth": "4.24.13",
    "otplib": "^13.3.0",
    "postcss": "^8.5.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.7.0",
    "resend": "^6.9.4",
    "swr": "2.2.4",
    "tailwindcss": "^4.2.1"
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "@playwright/test": "^1.57.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "8.57.1",
    "eslint-config-next": "15.3.9",
    "node-mocks-http": "^1.17.2",
    "playwright": "^1.57.0",
    "prisma": "6.19.2",
    "ts-node": "10.9.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.18"
  },
  "dockerfile": {
    "litestream": true
  }
}
